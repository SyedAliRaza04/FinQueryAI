# FinQuery AI Environment Variables Template
# Copy this to .env and fill in the values

# --- Django Settings ---
# Generate a secure key using: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secure-production-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Security & Auth ---
# JWT Secret Key (Can be the same as DJANGO_SECRET_KEY but dedicated is better for rotation)
JWT_SECRET_KEY=your-jwt-secret-here
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database Paths ---
# Internal banking DB for demo (SQLite)
BANKING_DATABASE_PATH=bank_customers.db
# Primary backend DB (PostgreSQL/SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/finquery

# --- Celery & Redis ---
# Required for async non-streaming queries and analytics
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Ollama / LLM Integration ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=120

# --- Caching ---
# Django cache alias (uses Redis)
CACHE_URL=redis://localhost:6379/1
